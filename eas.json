{\n  "cli": {\n    "version": ">= 5.0.0",\n    "requireCommit": true\n  },\n  "build": {\n    "development": {\n      "developmentClient": true,\n      "distribution": "internal",\n      "ios": {\n        "buildType": "simulator"\n      },\n      "android": {\n        "buildType": "apk"\n      }\n    },\n    "preview": {\n      "distribution": "internal",\n      "ios": {\n        "buildType": "archive"\n      },\n      "android": {\n        "buildType": "apk"\n      }\n    },\n    "staging": {\n      "distribution": "internal",\n      "releaseChannel": "staging",\n      "ios": {\n        \"buildType\": \"archive\",\n        \"certificateSource\": \"local\"\n      },\n      \"android\": {\n        \"buildType\": \"apk\",\n        \"keystore\": \"keystore.jks\"\n      }\n    },\n    \"production\": {\n      \"distribution\": \"store\",\n      \"releaseChannel\": \"production\",\n      \"ios\": {\n        \"buildType\": \"archive\",\n        \"certificateSource\": \"local\",\n        \"provisioning\": \"adhoc\"\n      },\n      \"android\": {\n        \"buildType\": \"aab\",\n        \"keystore\": \"keystore.jks\"\n      }\n    }\n  },\n  \"submit\": {\n    \"production\": {\n      \"ios\": {\n        \"appleId\": \"$APPLE_ID\",\n        \"applePassword\": \"$APPLE_PASSWORD\",\n        \"appleTeamId\": \"$APPLE_TEAM_ID\",\n        \"ascAppId\": \"$ASC_APP_ID\"\n      },\n      \"android\": {\n        \"serviceAccountKeyPath\": \"$GOOGLE_PLAY_KEY_PATH\",\n        \"track\": \"production\"\n      }\n    }\n  }\n}\n
